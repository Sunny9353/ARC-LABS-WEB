rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && (
          request.auth.token.admin == true
          || request.auth.token.email == "techarclab@gmail.com"
          || request.auth.token.email == "techarclabs@gmail.com"
          || request.auth.token.email == "arcadmin@gmail.com"
        );
    }

    function isPaidOrderWrite() {
      return request.resource.data.paymentId is string
        && request.resource.data.razorpayOrderId is string
        && (
          request.resource.data.status == "Paid"
          || request.resource.data.status == "paid"
          || request.resource.data.status == "captured"
          || request.resource.data.status == "success"
        );
    }

    function isFailedOrderWrite() {
      return request.resource.data.status == "Failed"
        && request.resource.data.razorpayOrderId is string
        && request.resource.data.paymentError is map
        && request.resource.data.paymentError.description is string;
    }

    // Public verification, tightly controlled creation from eligible registrations.
    match /certificates/{certId} {
      allow read: if true;
      allow create: if request.resource.data.eligibleStudentId is string
        && exists(/databases/$(database)/documents/certificateEligibleRegistrations/$(request.resource.data.eligibleStudentId))
        && !("certificateId" in get(/databases/$(database)/documents/certificateEligibleRegistrations/$(request.resource.data.eligibleStudentId)).data);
      allow list, update, delete: if isAdmin();
    }

    match /certificateEligibleStudents/{rollKey} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /certificateEligibleRegistrations/{eligibilityId} {
      allow get: if true;
      allow list, create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["certificateId", "certificateRegisteredAt"])
          && !("certificateId" in resource.data)
        );
    }

    match /orders/{orderId} {
      allow create: if isPaidOrderWrite() || isFailedOrderWrite();
      allow read: if isAdmin();
      allow update: if isAdmin()
        || (
          isPaidOrderWrite()
          && resource.data.paymentId == request.resource.data.paymentId
        );
      allow delete: if false;
    }

    match /invoices/{invoiceId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /counters/{counterId} {
      allow read, write: if false;
    }

    match /analyticsEvents/{eventId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /telemetry_data/{telemetryId} {
      allow create: if request.resource.data.latitude is number
        && request.resource.data.longitude is number
        && request.resource.data.pagePath is string;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /programCurriculumLeads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /custom_proposals/{proposalId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /csrPartnershipLeads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /contactEnquiries/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /orderEvents/{eventId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
